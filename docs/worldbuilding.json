    "value_table": {
      "5_copper_coins": "a loaf of bread",
      "20-50_copper_coins": "one meal at a village restaurant",
      "1-2_silver_coins": "one day lodging + meals",
      "10-20_silver_coins": "one basic weapon/armor",
